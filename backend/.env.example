# ── Plaid ────────────────────────────────────────────────────────────────────
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=sandbox   # sandbox | development | production
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PLAID_TOKEN_KEY=64_hex_chars_here

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...         # from `stripe listen` or Stripe dashboard
STRIPE_CLIENT_ID=ca_...                 # Connect application client_id (Stripe Connect Standard)
STRIPE_CONNECT_REDIRECT_URI=https://your-domain.com/api/nonprofits/connect-callback

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your_session_secret_here

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3001
DATABASE_PATH=./pocketcache.db
FRONTEND_URL=https://bpangman.github.io
# For local dev: FRONTEND_URL=http://localhost:5173
