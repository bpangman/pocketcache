{
  "appId": "app.pocketcache",
  "appName": "PocketCache",
  "webDir": "www",
  "backgroundColor": "#0B2A4A",
  "server": {
    "url": "https://pocketcache.app/demo/"
  },
  "ios": {
    "contentInset": "never",
    "allowsLinkPreview": false,
    "backgroundColor": "#0B2A4A"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 0,
      "launchAutoHide": false,
      "backgroundColor": "#0B2A4A",
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "LIGHT",
      "overlaysWebView": false,
      "backgroundColor": "#0B2A4A"
    }
  }
}
